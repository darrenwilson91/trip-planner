---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A curated destination guide for Darren & Anthony — with allergen safety ratings for every destination" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Darren & Anthony's Trip Planner</title>
  </head>
  <body class="bg-stone-50 text-stone-800 font-sans">
    <header class="border-b border-stone-200 bg-white">
      <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
        <a href="/" class="text-lg font-semibold text-stone-900 hover:text-stone-600 transition-colors">
          Darren & Anthony's Trip Planner
        </a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-stone-200 bg-white mt-16">
      <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8 text-center text-sm text-stone-500">
        &copy; {new Date().getFullYear()} Darren & Anthony's Trip Planner
      </div>
    </footer>
  </body>
</html>
