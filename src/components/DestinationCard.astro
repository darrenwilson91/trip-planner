---
interface Props {
  title: string;
  country: string;
  region: string;
  slug: string;
  heroImage: string;
  heroImageAlt: string;
  summary: string;
  tripLength: string;
  hotelCostPerNight: number;
  flightCostReturn: number;
  nutAllergyRating: number;
  vegetarianRating: number;
}

const {
  title,
  country,
  slug,
  heroImage,
  heroImageAlt,
  summary,
  tripLength,
  hotelCostPerNight,
  flightCostReturn,
  nutAllergyRating,
  vegetarianRating,
} = Astro.props;

function badgeClasses(rating: number): string {
  if (rating >= 4) return "bg-emerald-100 text-emerald-800";
  if (rating === 3) return "bg-amber-100 text-amber-800";
  return "bg-red-100 text-red-800";
}
---

<a href={`/destinations/${slug}`} class="block bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden">
  <img
    src={heroImage}
    alt={heroImageAlt}
    loading="lazy"
    decoding="async"
    class="w-full aspect-[3/2] object-cover"
  />
  <div class="p-4">
    <h3 class="text-lg font-semibold text-stone-900">{title}</h3>
    <p class="text-sm text-stone-500">{country}</p>
    <p class="mt-2 text-sm text-stone-600 line-clamp-2">{summary}</p>
    <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-stone-500">
      <span>{tripLength}</span>
      <span>&pound;{hotelCostPerNight}/night</span>
      <span>&pound;{flightCostReturn} return</span>
    </div>
    <div class="mt-3 flex flex-wrap gap-2">
      <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-medium ${badgeClasses(nutAllergyRating)}`}>
        Nut Safe: {nutAllergyRating}/5
      </span>
      <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-medium ${badgeClasses(vegetarianRating)}`}>
        Veggie: {vegetarianRating}/5
      </span>
    </div>
  </div>
</a>
